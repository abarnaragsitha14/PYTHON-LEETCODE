class Solution:
    def findItinerary(self, tickets: List[List[str]]) -> List[str]:
        #sort the tickets
        tickets.sort(reverse=True)
        graph=defaultdict(list)
        for src,dst in tickets:
            graph[src].append(dst)
        stack=["JFK"]
        res=[]
        while stack:
            if graph[stack[-1]]:
                stack.append(graph[stack[-1]].pop())
            else:
                res.append(stack.pop())
        return res[::-1]
        
